# ============================================
# HRIS Docker Environment Configuration
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env
# ============================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hris_db
DB_PORT=5432

# Connection string (used by the app container)
DATABASE_URL="postgresql://postgres:postgres@db:5432/hris_db?schema=public"

# --- Auth.js ---
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="CHANGE-THIS-TO-A-RANDOM-SECRET"
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
APP_PORT=3000
